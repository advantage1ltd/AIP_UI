# Optional when the API is served from the same origin at /api.
# Required when the API is on another host (include the /api suffix).
VITE_API_BASE_URL=https://your-api-host.example/api

# Backend URL for `npm run dev` when not using the default localhost target.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:5128

# Verbose client logging in development only.
VITE_DEBUG_LOGS=false

# Optional Axios timeout in milliseconds.
VITE_API_TIMEOUT_MS=30000

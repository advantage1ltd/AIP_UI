{
  "name": "aip-web-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:all": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:critical": "eslint \"src/App.tsx\" \"src/contexts/AuthContext.tsx\" \"src/contexts/PageAccessContext.tsx\" \"src/components/ProtectedRoute.tsx\" \"src/state/sessionStore.ts\" \"src/config/api.ts\" \"src/api/pageAccess.ts\" \"src/pages/LoginPage.tsx\" \"src/pages/operations/IncidentReportPage.tsx\" \"src/utils/page-access-guards.ts\" --max-warnings 0",
    "typecheck": "tsc --noEmit --project tsconfig.app.json",
    "typecheck:critical": "tsc --noEmit --project tsconfig.quality.json",
    "test": "jest --runInBand",
    "test:ci": "jest --coverage --runInBand",
    "quality:check": "npm run typecheck:critical && npm run lint:critical && npm run test:ci",
    "preview": "vite preview"
